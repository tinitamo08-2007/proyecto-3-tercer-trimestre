# === Opción A: MySQL local ===
db.url=jdbc:mysql://localhost:3306/granja_digital?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
db.usuario=root
db.clave=TU_CONTRASENA_LOCAL

# === Opción B: MySQL en la nube (Aiven, AWS RDS, PlanetScale...) ===
# Descomenta las 3 líneas siguientes y comenta las de arriba.
